# Copy this file to .env and fill in real values.
# python-dotenv (already in requirements.txt) loads this automatically.

# --- Core ---
SECRET_KEY=change-this-to-a-long-random-secret-key
FLASK_DEBUG=1
PORT=5000
SITE_URL=https://your-domain.com

# --- Admin access (analytics dashboard, blog publishing) ---
ADMIN_TOKEN=change-this-to-something-only-you-know

# --- Email (SMTP) — used for contact form + newsletter confirmations ---
# For Gmail: create an "App Password" at https://myaccount.google.com/apppasswords
# Leave these unset and the site still works — emails are just logged, not sent.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_SENDER=your_email@gmail.com

# --- Error tracking (optional) ---
# Create a free project at https://sentry.io to get a DSN.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
